APP_ENV=development
ENABLE_DEV_ENDPOINTS=true
RECAPTCHA_ENABLED=true
RECAPTCHA_USE_GOOGLE_TEST_KEYS=false
RECAPTCHA_FAIL_OPEN_ON_LOCALHOST=false
DATABASE_URL=mysql+pymysql://root:replace-with-db-password@localhost/skillswap
SECRET_KEY=replace-with-a-secure-random-value
SUPER_ADMIN_PASSWORD=replace-with-strong-super-admin-password
ADMIN_EMAIL=admin@example.com

MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=replace-with-mail-username
MAIL_PASSWORD=replace-with-mail-password
MAIL_DEFAULT_SENDER=replace-with-default-sender

RECAPTCHA_SITE_KEY=replace-with-recaptcha-site-key
RECAPTCHA_SECRET_KEY=replace-with-recaptcha-secret-key

GROQ_API_KEY=replace-with-groq-api-key
GROQ_MODEL_PRIMARY=llama-3.1-8b-instant
GROQ_MODEL_FALLBACKS=llama-3.3-70b-versatile,meta-llama/llama-4-scout-17b-16e-instruct


